---
---

<div class="w-full max-w-md mx-auto bg-slate-900/90 border border-sky-900/50 rounded-3xl shadow-2xl overflow-hidden p-6 sm:p-8 backdrop-blur-xl">
  <div class="text-center mb-6">
    <div class="w-16 h-16 bg-gradient-to-tr from-sky-500/20 to-orange-500/20 border border-sky-500/30 rounded-2xl flex items-center justify-center mx-auto mb-4 text-orange-400 shadow-inner">
      <svg class="w-9 h-9 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
      </svg>
    </div>
    <h2 class="text-2xl font-bold text-white tracking-tight">Acceso al Sistema</h2>
    <p class="text-xs text-sky-300 mt-1">Ingresa tus credenciales únicas de la empresa</p>
  </div>

  <div id="loginAlert" class="hidden mb-5 p-3.5 bg-red-500/10 border border-red-500/30 rounded-2xl text-red-400 text-sm font-semibold text-center"></div>

  <form id="loginForm" class="space-y-5">
    <div>
      <label for="usuario" class="block text-xs font-bold text-sky-200 uppercase tracking-wider mb-2">Usuario</label>
      <input 
        type="text" 
        id="usuario" 
        name="usuario" 
        required 
        placeholder="Tu usuario (ej. admin u operario1)"
        class="w-full px-4 py-3 bg-slate-950/80 border border-sky-900/60 rounded-2xl text-white placeholder-slate-500 focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 transition-all touch-target text-base"
      />
    </div>

    <div>
      <label for="password" class="block text-xs font-bold text-sky-200 uppercase tracking-wider mb-2">Contraseña</label>
      <input 
        type="password" 
        id="password" 
        name="password" 
        required 
        placeholder="••••••••"
        class="w-full px-4 py-3 bg-slate-950/80 border border-sky-900/60 rounded-2xl text-white placeholder-slate-500 focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 transition-all touch-target text-base"
      />
    </div>

    <button 
      type="submit" 
      id="submitBtn"
      class="w-full touch-target bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-extrabold rounded-2xl transition-all shadow-lg shadow-orange-500/30 active:scale-[0.98] flex items-center justify-center text-base uppercase tracking-wide"
    >
      <span id="btnText">Iniciar Sesión</span>
    </button>
  </form>

  <div class="mt-6 pt-4 border-t border-sky-900/40 text-center text-xs text-slate-400">
    <p class="font-medium text-slate-300">Detección automática de rol (Operario o TI):</p>
    <p class="font-mono mt-1 text-sky-400">Admin TI: admin / admin123</p>
    <p class="font-mono text-orange-400">Operario: operario1 / operario123</p>
  </div>
</div>

<script>
  const form = document.getElementById('loginForm') as HTMLFormElement;
  const alertDiv = document.getElementById('loginAlert') as HTMLDivElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const btnText = document.getElementById('btnText') as HTMLSpanElement;

  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('error') === 'unauthorized') {
    alertDiv.innerText = 'Debes iniciar sesión para acceder al sistema.';
    alertDiv.classList.remove('hidden');
    sessionStorage.clear();
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      alertDiv.classList.add('hidden');
      submitBtn.disabled = true;
      btnText.innerText = 'Autenticando...';

      const formData = new FormData(form);
      const usuario = formData.get('usuario');
      const password = formData.get('password');

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ usuario, password }),
        });

        const data = await res.json();

        if (res.ok && data.success) {
          // Registrar estado de sesión activa en la pestaña/ventana actual
          sessionStorage.setItem('fn_session_active', 'true');
          sessionStorage.setItem('fn_user_role', data.user?.rol || '');

          if (data.user?.rol === 'Administrador') {
            window.location.href = '/dashboard';
          } else {
            window.location.href = '/operario';
          }
        } else {
          sessionStorage.clear();
          alertDiv.innerText = data.error || 'Credenciales inválidas.';
          alertDiv.classList.remove('hidden');
        }
      } catch (err) {
        sessionStorage.clear();
        alertDiv.innerText = 'Error de comunicación con el servidor.';
        alertDiv.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        btnText.innerText = 'Iniciar Sesión';
      }
    });
  }
</script>
