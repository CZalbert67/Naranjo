---
---

<div class="w-full max-w-md mx-auto bg-slate-900 border border-slate-800 rounded-2xl shadow-2xl overflow-hidden p-6 sm:p-8">
  <!-- Pestañas de Selección de Perfil / Login -->
  <div class="grid grid-cols-2 gap-2 p-1.5 bg-slate-950 rounded-xl mb-6 border border-slate-800/80">
    <button 
      type="button" 
      id="tabOperario"
      class="py-2.5 px-3 rounded-lg text-xs font-bold transition-all text-center flex items-center justify-center space-x-1.5 bg-amber-500 text-slate-950 shadow-md"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      <span>1. Operarios (Planta)</span>
    </button>

    <button 
      type="button" 
      id="tabAdmin"
      class="py-2.5 px-3 rounded-lg text-xs font-bold transition-all text-center flex items-center justify-center space-x-1.5 text-slate-400 hover:text-white"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
      </svg>
      <span>2. Departamento de TI</span>
    </button>
  </div>

  <div class="text-center mb-6">
    <div id="roleBadgeIcon" class="w-14 h-14 bg-amber-500/10 border border-amber-500/30 rounded-2xl flex items-center justify-center mx-auto mb-3 text-amber-400">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
    </div>
    <h2 id="roleTitle" class="text-2xl font-bold text-white tracking-tight">Acceso Operario de Planta</h2>
    <p id="roleDescription" class="text-xs text-slate-400 mt-1">Portal para levantar reportes de fallas técnicas en maquinaria y red</p>
  </div>

  <div id="loginAlert" class="hidden mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-xl text-red-400 text-sm font-medium text-center"></div>

  <form id="loginForm" class="space-y-5">
    <div>
      <label for="usuario" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-2">Usuario</label>
      <input 
        type="text" 
        id="usuario" 
        name="usuario" 
        required 
        value="operario1"
        placeholder="Ingrese usuario de planta..."
        class="w-full px-4 py-3 bg-slate-950 border border-slate-800 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 transition-all touch-target text-base"
      />
    </div>

    <div>
      <label for="password" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-2">Contraseña</label>
      <input 
        type="password" 
        id="password" 
        name="password" 
        required 
        value="operario123"
        placeholder="••••••••"
        class="w-full px-4 py-3 bg-slate-950 border border-slate-800 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 transition-all touch-target text-base"
      />
    </div>

    <button 
      type="submit" 
      id="submitBtn"
      class="w-full touch-target bg-amber-500 hover:bg-amber-400 text-slate-950 font-bold rounded-xl transition-all shadow-lg shadow-amber-500/25 active:scale-[0.98] flex items-center justify-center text-base uppercase tracking-wide"
    >
      <span id="btnText">Ingresar como Operario</span>
    </button>
  </form>

  <!-- Acceso rápido directo a formularios -->
  <div class="mt-6 pt-4 border-t border-slate-800/80 space-y-2">
    <a href="/operario" class="w-full py-2.5 px-3 bg-slate-800 hover:bg-slate-700/80 text-amber-400 border border-slate-700/60 rounded-xl text-xs font-semibold flex items-center justify-center space-x-2 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      <span>Ir directo a Levantamiento de Orden (Modo Rápido)</span>
    </a>
    <a href="/dashboard" class="w-full py-2.5 px-3 bg-slate-800/50 hover:bg-slate-800 text-slate-300 border border-slate-800 rounded-xl text-xs font-semibold flex items-center justify-center space-x-2 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <span>Ir directo a Dashboard de Sistemas (Modo TI)</span>
    </a>
  </div>
</div>

<script>
  let currentRole: 'Operario' | 'Administrador' = 'Operario';

  const tabOperario = document.getElementById('tabOperario') as HTMLButtonElement;
  const tabAdmin = document.getElementById('tabAdmin') as HTMLButtonElement;
  
  const roleTitle = document.getElementById('roleTitle') as HTMLHeadingElement;
  const roleDescription = document.getElementById('roleDescription') as HTMLParagraphElement;
  const userInput = document.getElementById('usuario') as HTMLInputElement;
  const passInput = document.getElementById('password') as HTMLInputElement;
  const btnText = document.getElementById('btnText') as HTMLSpanElement;

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const alertDiv = document.getElementById('loginAlert') as HTMLDivElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  function setRoleMode(role: 'Operario' | 'Administrador') {
    currentRole = role;
    if (role === 'Operario') {
      tabOperario.className = 'py-2.5 px-3 rounded-lg text-xs font-bold transition-all text-center flex items-center justify-center space-x-1.5 bg-amber-500 text-slate-950 shadow-md';
      tabAdmin.className = 'py-2.5 px-3 rounded-lg text-xs font-bold transition-all text-center flex items-center justify-center space-x-1.5 text-slate-400 hover:text-white';
      
      roleTitle.innerText = 'Acceso Operario de Planta';
      roleDescription.innerText = 'Portal para levantar reportes de fallas técnicas en maquinaria y red';
      userInput.value = 'operario1';
      passInput.value = 'operario123';
      btnText.innerText = 'Ingresar como Operario';
    } else {
      tabAdmin.className = 'py-2.5 px-3 rounded-lg text-xs font-bold transition-all text-center flex items-center justify-center space-x-1.5 bg-amber-500 text-slate-950 shadow-md';
      tabOperario.className = 'py-2.5 px-3 rounded-lg text-xs font-bold transition-all text-center flex items-center justify-center space-x-1.5 text-slate-400 hover:text-white';
      
      roleTitle.innerText = 'Acceso Departamento de TI';
      roleDescription.innerText = 'Panel de control exclusivo para el Encargado de Sistemas';
      userInput.value = 'admin';
      passInput.value = 'admin123';
      btnText.innerText = 'Ingresar como Encargado de TI';
    }
  }

  if (tabOperario && tabAdmin) {
    tabOperario.addEventListener('click', () => setRoleMode('Operario'));
    tabAdmin.addEventListener('click', () => setRoleMode('Administrador'));
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      alertDiv.classList.add('hidden');
      submitBtn.disabled = true;
      btnText.innerText = 'Verificando credenciales...';

      const usuario = userInput.value;
      const password = passInput.value;

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ usuario, password }),
        });

        const data = await res.json();

        if (res.ok && data.success) {
          if (data.user?.rol === 'Administrador') {
            window.location.href = '/dashboard';
          } else {
            window.location.href = '/operario';
          }
        } else {
          alertDiv.innerText = data.error || 'Credenciales inválidas.';
          alertDiv.classList.remove('hidden');
        }
      } catch (err) {
        alertDiv.innerText = 'Error de comunicación con el servidor.';
        alertDiv.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        btnText.innerText = currentRole === 'Operario' ? 'Ingresar como Operario' : 'Ingresar como Encargado de TI';
      }
    });
  }
</script>
