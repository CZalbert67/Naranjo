---
---

<div class="space-y-6">
  <!-- Pestañas Principales del Dashboard de TI -->
  <div class="flex border-b border-sky-900/50 space-x-4">
    <button 
      id="tabTickets" 
      class="pb-3 px-2 font-bold text-sm text-orange-400 border-b-2 border-orange-500 flex items-center space-x-2 transition-all"
    >
      <svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <span>Gestión de Órdenes de Trabajo</span>
    </button>

    <button 
      id="tabUsers" 
      class="pb-3 px-2 font-bold text-sm text-slate-400 hover:text-sky-300 border-b-2 border-transparent transition-all flex items-center space-x-2"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
      <span>Alta & Control de Usuarios</span>
    </button>
  </div>

  <!-- SECCIÓN 1: DÁSHBOARD DE TICKETS -->
  <div id="sectionTickets" class="space-y-6">
    <!-- Tarjetas de Resumen KPI -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-slate-900/80 border border-sky-900/50 p-4 rounded-2xl">
        <p class="text-xs font-bold text-sky-400 uppercase">Total Activas</p>
        <p id="kpiTotal" class="text-3xl font-black text-white mt-1">0</p>
      </div>
      <div class="bg-slate-900/80 border border-orange-500/30 p-4 rounded-2xl">
        <p class="text-xs font-bold text-orange-400 uppercase">En Proceso</p>
        <p id="kpiProceso" class="text-3xl font-black text-orange-400 mt-1">0</p>
      </div>
      <div class="bg-slate-900/80 border border-red-500/30 p-4 rounded-2xl">
        <p class="text-xs font-bold text-red-400 uppercase">Pendientes</p>
        <p id="kpiPendientes" class="text-3xl font-black text-red-400 mt-1">0</p>
      </div>
      <div class="bg-slate-900/80 border border-emerald-500/30 p-4 rounded-2xl">
        <p class="text-xs font-bold text-emerald-400 uppercase">Resueltas Hoy</p>
        <p id="kpiResueltas" class="text-3xl font-black text-emerald-400 mt-1">0</p>
      </div>
    </div>

    <!-- Contenedor de la Tabla de Tickets -->
    <div class="bg-slate-900/80 border border-sky-900/50 rounded-3xl overflow-hidden shadow-2xl backdrop-blur-md">
      <div class="p-4 sm:p-6 border-b border-sky-900/50 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold text-white">Órdenes de Trabajo Activas</h2>
          <p class="text-xs text-sky-300">Monitoreo y resolución técnica en tiempo real</p>
        </div>

        <button 
          id="btnRefresh" 
          class="bg-slate-800 hover:bg-slate-700 text-slate-200 border border-sky-900/60 px-4 py-2 rounded-xl text-sm font-semibold transition-all flex items-center space-x-2 touch-target"
        >
          <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          <span>Actualizar Tabla</span>
        </button>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-slate-300">
          <thead class="bg-slate-950/80 text-xs font-bold text-sky-400 uppercase border-b border-sky-900/60">
            <tr>
              <th class="px-4 py-3.5">ID Ticket</th>
              <th class="px-4 py-3.5">Fecha</th>
              <th class="px-4 py-3.5">Área / Equipo TI</th>
              <th class="px-4 py-3.5">Descripción de Falla</th>
              <th class="px-4 py-3.5">Operario</th>
              <th class="px-4 py-3.5">Estado</th>
              <th class="px-4 py-3.5 text-right">Acciones</th>
            </tr>
          </thead>
          <tbody id="ticketsTableBody" class="divide-y divide-sky-900/30">
            <tr>
              <td colspan="7" class="px-4 py-8 text-center text-slate-500">Cargando órdenes de trabajo...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- SECCIÓN 2: ALTA Y CONTROL DE USUARIOS -->
  <div id="sectionUsers" class="hidden space-y-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Formulario de Registro de Usuario -->
      <div class="lg:col-span-1 bg-slate-900/80 border border-sky-900/50 rounded-3xl p-6 shadow-2xl h-fit">
        <div class="flex items-center space-x-3 mb-5 pb-3 border-b border-sky-900/50">
          <div class="w-10 h-10 bg-orange-500/10 border border-orange-500/30 rounded-xl flex items-center justify-center text-orange-400">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white">Dar de Alta Usuario</h3>
            <p class="text-xs text-sky-300">Registrar nuevo Empleado o Admin TI</p>
          </div>
        </div>

        <div id="userAlert" class="hidden mb-4 p-3 bg-emerald-500/10 border border-emerald-500/30 rounded-xl text-emerald-400 text-xs font-semibold"></div>

        <form id="newUserForm" class="space-y-4">
          <div>
            <label for="nombre_completo" class="block text-xs font-bold text-sky-200 uppercase mb-1">Nombre Completo</label>
            <input 
              type="text" 
              id="nombre_completo" 
              name="nombre_completo" 
              required 
              placeholder="Ej. Carlos Mendoza (Tejeduría)"
              class="w-full px-3.5 py-2.5 bg-slate-950/80 border border-sky-900/60 rounded-xl text-white text-sm focus:outline-none focus:border-orange-500"
            />
          </div>

          <div>
            <label for="new_usuario" class="block text-xs font-bold text-sky-200 uppercase mb-1">Nombre de Usuario</label>
            <input 
              type="text" 
              id="new_usuario" 
              name="usuario" 
              required 
              placeholder="ej. cmendoza"
              class="w-full px-3.5 py-2.5 bg-slate-950/80 border border-sky-900/60 rounded-xl text-white text-sm focus:outline-none focus:border-orange-500"
            />
          </div>

          <div>
            <label for="new_password" class="block text-xs font-bold text-sky-200 uppercase mb-1">Contraseña</label>
            <input 
              type="password" 
              id="new_password" 
              name="password" 
              required 
              placeholder="••••••••"
              class="w-full px-3.5 py-2.5 bg-slate-950/80 border border-sky-900/60 rounded-xl text-white text-sm focus:outline-none focus:border-orange-500"
            />
          </div>

          <div>
            <label for="rol" class="block text-xs font-bold text-sky-200 uppercase mb-1">Rol de Acceso</label>
            <select 
              id="rol" 
              name="rol" 
              required 
              class="w-full px-3.5 py-2.5 bg-slate-950/80 border border-sky-900/60 rounded-xl text-white text-sm focus:outline-none focus:border-orange-500"
            >
              <option value="Operario">Operario (Levantar Reportes)</option>
              <option value="Administrador">Administrador (Departamento de TI)</option>
            </select>
          </div>

          <button 
            type="submit" 
            id="btnCreateUser"
            class="w-full touch-target bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-extrabold rounded-xl transition-all shadow-md shadow-orange-500/20 text-sm uppercase tracking-wide mt-2"
          >
            Registrar Usuario
          </button>
        </form>
      </div>

      <!-- Tabla de Usuarios Registrados -->
      <div class="lg:col-span-2 bg-slate-900/80 border border-sky-900/50 rounded-3xl p-6 shadow-2xl">
        <div class="flex items-center justify-between mb-5 pb-3 border-b border-sky-900/50">
          <div>
            <h3 class="text-lg font-bold text-white">Directorio de Usuarios</h3>
            <p class="text-xs text-sky-300">Personal de Planta y TI autorizados</p>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm text-slate-300">
            <thead class="bg-slate-950/80 text-xs font-bold text-sky-400 uppercase border-b border-sky-900/60">
              <tr>
                <th class="px-4 py-3">ID</th>
                <th class="px-4 py-3">Nombre Completo</th>
                <th class="px-4 py-3">Usuario</th>
                <th class="px-4 py-3">Rol</th>
              </tr>
            </thead>
            <tbody id="usersTableBody" class="divide-y divide-sky-900/30">
              <tr>
                <td colspan="4" class="px-4 py-8 text-center text-slate-500">Cargando directorio de usuarios...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  interface Ticket {
    id_ticket: number;
    id_usuario: number;
    nombre_usuario?: string;
    id_equipo: number;
    nombre_equipo?: string;
    nombre_area?: string;
    descripcion: string;
    estado: 'Pendiente' | 'En Proceso' | 'Resuelto';
    fecha_reporte: string;
  }

  interface User {
    id_usuario: number;
    nombre_completo: string;
    usuario: string;
    rol: 'Operario' | 'Administrador';
  }

  // Pestañas
  const tabTickets = document.getElementById('tabTickets') as HTMLButtonElement;
  const tabUsers = document.getElementById('tabUsers') as HTMLButtonElement;
  const sectionTickets = document.getElementById('sectionTickets') as HTMLDivElement;
  const sectionUsers = document.getElementById('sectionUsers') as HTMLDivElement;

  // KPIs y Tablas
  const tableBody = document.getElementById('ticketsTableBody') as HTMLTableSectionElement;
  const usersTableBody = document.getElementById('usersTableBody') as HTMLTableSectionElement;
  const btnRefresh = document.getElementById('btnRefresh') as HTMLButtonElement;

  const kpiTotal = document.getElementById('kpiTotal') as HTMLParagraphElement;
  const kpiProceso = document.getElementById('kpiProceso') as HTMLParagraphElement;
  const kpiPendientes = document.getElementById('kpiPendientes') as HTMLParagraphElement;
  const kpiResueltas = document.getElementById('kpiResueltas') as HTMLParagraphElement;

  // Formulario Usuario
  const newUserForm = document.getElementById('newUserForm') as HTMLFormElement;
  const userAlert = document.getElementById('userAlert') as HTMLDivElement;
  const btnCreateUser = document.getElementById('btnCreateUser') as HTMLButtonElement;

  // Manejo de Pestañas
  if (tabTickets && tabUsers) {
    tabTickets.addEventListener('click', () => {
      tabTickets.className = 'pb-3 px-2 font-bold text-sm text-orange-400 border-b-2 border-orange-500 flex items-center space-x-2 transition-all';
      tabUsers.className = 'pb-3 px-2 font-bold text-sm text-slate-400 hover:text-sky-300 border-b-2 border-transparent transition-all flex items-center space-x-2';
      sectionTickets.classList.remove('hidden');
      sectionUsers.classList.add('hidden');
    });

    tabUsers.addEventListener('click', () => {
      tabUsers.className = 'pb-3 px-2 font-bold text-sm text-orange-400 border-b-2 border-orange-500 flex items-center space-x-2 transition-all';
      tabTickets.className = 'pb-3 px-2 font-bold text-sm text-slate-400 hover:text-sky-300 border-b-2 border-transparent transition-all flex items-center space-x-2';
      sectionUsers.classList.remove('hidden');
      sectionTickets.classList.add('hidden');
      fetchUsers();
    });
  }

  async function fetchTickets() {
    try {
      tableBody.innerHTML = `<tr><td colspan="7" class="px-4 py-8 text-center text-slate-500">Cargando datos...</td></tr>`;
      const res = await fetch('/api/tickets');
      const tickets: Ticket[] = await res.json();
      renderTickets(tickets);
    } catch (err) {
      tableBody.innerHTML = `<tr><td colspan="7" class="px-4 py-8 text-center text-red-400">Error al cargar los tickets.</td></tr>`;
    }
  }

  function renderTickets(tickets: Ticket[]) {
    if (!tickets || tickets.length === 0) {
      tableBody.innerHTML = `<tr><td colspan="7" class="px-4 py-8 text-center text-slate-500">No hay tickets activos registrados.</td></tr>`;
      updateKPIs([]);
      return;
    }

    updateKPIs(tickets);
    tableBody.innerHTML = '';

    tickets.forEach((t) => {
      const tr = document.createElement('tr');
      tr.className = 'hover:bg-slate-800/40 transition-colors';

      let statusBadge = '';
      if (t.estado === 'Pendiente') {
        statusBadge = `<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-red-500/10 text-red-400 border border-red-500/30">Pendiente</span>`;
      } else if (t.estado === 'En Proceso') {
        statusBadge = `<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-orange-500/10 text-orange-400 border border-orange-500/30">En Proceso</span>`;
      } else {
        statusBadge = `<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/30">Resuelto</span>`;
      }

      const formattedDate = new Date(t.fecha_reporte).toLocaleString('es-MX', {
        day: '2-digit',
        month: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
      });

      tr.innerHTML = `
        <td class="px-4 py-4 font-mono font-bold text-orange-400">#TK-${t.id_ticket}</td>
        <td class="px-4 py-4 text-xs text-slate-400">${formattedDate}</td>
        <td class="px-4 py-4">
          <p class="font-semibold text-white">${t.nombre_equipo || `Equipo TI #${t.id_equipo}`}</p>
          <p class="text-xs text-sky-400">${t.nombre_area || 'Área General'}</p>
        </td>
        <td class="px-4 py-4 max-w-xs text-slate-200 truncate" title="${t.descripcion}">${t.descripcion}</td>
        <td class="px-4 py-4 text-xs text-slate-300">${t.nombre_usuario || 'Operario'}</td>
        <td class="px-4 py-4">${statusBadge}</td>
        <td class="px-4 py-4 text-right space-x-2">
          ${t.estado !== 'Resuelto' ? `
            <button 
              data-id="${t.id_ticket}" 
              data-status="En Proceso"
              class="btn-change-status text-xs bg-orange-500/10 hover:bg-orange-500/20 text-orange-400 border border-orange-500/30 px-3 py-1.5 rounded-xl transition-colors font-semibold"
            >
              En Proceso
            </button>
            <button 
              data-id="${t.id_ticket}" 
              data-status="Resuelto"
              class="btn-change-status text-xs bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 px-3 py-1.5 rounded-xl transition-colors font-semibold"
            >
              Resuelto
            </button>
          ` : '<span class="text-xs text-slate-500 font-medium">Finalizado</span>'}
        </td>
      `;

      tableBody.appendChild(tr);
    });

    document.querySelectorAll('.btn-change-status').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const id = target.getAttribute('data-id');
        const newStatus = target.getAttribute('data-status');
        if (id && newStatus) {
          await updateTicketStatus(parseInt(id, 10), newStatus);
        }
      });
    });
  }

  function updateKPIs(tickets: Ticket[]) {
    if (kpiTotal) kpiTotal.innerText = tickets.length.toString();
    if (kpiPendientes) kpiPendientes.innerText = tickets.filter((t) => t.estado === 'Pendiente').length.toString();
    if (kpiProceso) kpiProceso.innerText = tickets.filter((t) => t.estado === 'En Proceso').length.toString();
    if (kpiResueltas) kpiResueltas.innerText = tickets.filter((t) => t.estado === 'Resuelto').length.toString();
  }

  async function updateTicketStatus(id: number, estado: string) {
    try {
      const res = await fetch(`/api/tickets/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ estado }),
      });
      if (res.ok) {
        fetchTickets();
      }
    } catch (err) {
      console.error('Error al actualizar ticket:', err);
    }
  }

  async function fetchUsers() {
    try {
      usersTableBody.innerHTML = `<tr><td colspan="4" class="px-4 py-8 text-center text-slate-500">Cargando directorio...</td></tr>`;
      const res = await fetch('/api/users');
      const users: User[] = await res.json();
      renderUsers(users);
    } catch (err) {
      usersTableBody.innerHTML = `<tr><td colspan="4" class="px-4 py-8 text-center text-red-400">Error al cargar usuarios.</td></tr>`;
    }
  }

  function renderUsers(users: User[]) {
    if (!users || users.length === 0) {
      usersTableBody.innerHTML = `<tr><td colspan="4" class="px-4 py-8 text-center text-slate-500">No hay usuarios registrados.</td></tr>`;
      return;
    }

    usersTableBody.innerHTML = '';
    users.forEach((u) => {
      const tr = document.createElement('tr');
      tr.className = 'hover:bg-slate-800/40 transition-colors';
      const isTI = u.rol === 'Administrador';

      tr.innerHTML = `
        <td class="px-4 py-3 text-xs font-mono text-slate-400">#USR-${u.id_usuario}</td>
        <td class="px-4 py-3 font-semibold text-white">${u.nombre_completo}</td>
        <td class="px-4 py-3 text-xs font-mono text-sky-300">${u.usuario}</td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold ${
            isTI 
              ? 'bg-orange-500/10 text-orange-400 border border-orange-500/30' 
              : 'bg-sky-500/10 text-sky-400 border border-sky-500/30'
          }">
            ${u.rol === 'Administrador' ? 'Departamento de TI' : 'Operario de Planta'}
          </span>
        </td>
      `;
      usersTableBody.appendChild(tr);
    });
  }

  if (newUserForm) {
    newUserForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      userAlert.classList.add('hidden');
      btnCreateUser.disabled = true;
      btnCreateUser.innerText = 'Registrando...';

      const formData = new FormData(newUserForm);
      const payload = {
        nombre_completo: formData.get('nombre_completo'),
        usuario: formData.get('usuario'),
        password: formData.get('password'),
        rol: formData.get('rol'),
      };

      try {
        const res = await fetch('/api/users', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await res.json();

        if (res.ok && data.success) {
          userAlert.innerText = data.message || 'Usuario registrado exitosamente.';
          userAlert.className = 'mb-4 p-3 bg-emerald-500/10 border border-emerald-500/30 rounded-xl text-emerald-400 text-xs font-semibold';
          userAlert.classList.remove('hidden');
          newUserForm.reset();
          fetchUsers();
        } else {
          userAlert.innerText = data.error || 'Error al registrar el usuario.';
          userAlert.className = 'mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-xl text-red-400 text-xs font-semibold';
          userAlert.classList.remove('hidden');
        }
      } catch (err) {
        userAlert.innerText = 'Error de conexión con el servidor.';
        userAlert.className = 'mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-xl text-red-400 text-xs font-semibold';
        userAlert.classList.remove('hidden');
      } finally {
        btnCreateUser.disabled = false;
        btnCreateUser.innerText = 'Registrar Usuario';
      }
    });
  }

  if (btnRefresh) {
    btnRefresh.addEventListener('click', fetchTickets);
  }

  fetchTickets();
</script>
