---
---

<div class="w-full max-w-xl mx-auto space-y-6">
  <!-- Pestañas del Operario (Nuevo Reporte vs Mis Reportes) -->
  <div class="flex border-b border-sky-900/50 space-x-4">
    <button 
      id="tabNewTicket" 
      class="pb-3 px-2 font-bold text-sm text-orange-400 border-b-2 border-orange-500 flex items-center space-x-2 transition-all"
    >
      <svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <span>Nuevo Reporte de Falla</span>
    </button>

    <button 
      id="tabMyTickets" 
      class="pb-3 px-2 font-bold text-sm text-slate-400 hover:text-sky-300 border-b-2 border-transparent transition-all flex items-center space-x-2"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <span>Historial de Mis Reportes</span>
    </button>
  </div>

  <!-- SECCIÓN 1: FORMULARIO DE NUEVO REPORTE -->
  <div id="sectionNewTicket" class="bg-slate-900/90 border border-sky-900/50 rounded-3xl shadow-2xl p-6 sm:p-8 backdrop-blur-xl space-y-6">
    <div class="flex items-center space-x-3.5 pb-4 border-b border-sky-900/50">
      <div class="w-12 h-12 bg-gradient-to-tr from-sky-500/20 to-orange-500/20 border border-sky-500/30 rounded-2xl flex items-center justify-center text-orange-400">
        <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-white">Reportar Falla Técnica (TI)</h2>
        <p class="text-xs text-sky-300">Genera una orden directa al Departamento de Sistemas</p>
      </div>
    </div>

    <!-- Banners de Alerta -->
    <div id="ticketSuccessAlert" class="hidden p-4 bg-emerald-500/10 border border-emerald-500/30 rounded-2xl text-emerald-400 text-sm font-semibold flex items-center space-x-2">
      <svg class="w-5 h-5 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <span id="ticketSuccessMessage">Reporte Enviado Exitosamente</span>
    </div>

    <div id="ticketErrorAlert" class="hidden p-4 bg-red-500/10 border border-red-500/30 rounded-2xl text-red-400 text-sm font-semibold flex items-center space-x-2">
      <svg class="w-5 h-5 flex-shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span id="ticketErrorMessage">Error al enviar el reporte.</span>
    </div>

    <form id="ticketForm" class="space-y-6">
      <div>
        <label for="selectArea" class="block text-xs font-bold text-sky-200 uppercase tracking-wider mb-2">
          1. Selecciona tu Área <span class="text-orange-400">*</span>
        </label>
        <select 
          id="selectArea" 
          name="id_area" 
          required 
          class="w-full px-4 py-3 bg-slate-950/80 border border-sky-900/60 rounded-2xl text-white focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 touch-target text-base"
        >
          <option value="">-- Seleccionar Área --</option>
        </select>
      </div>

      <div>
        <label for="selectEquipo" class="block text-xs font-bold text-sky-200 uppercase tracking-wider mb-2">
          2. Selecciona el Equipo de TI <span class="text-orange-400">*</span>
        </label>
        <select 
          id="selectEquipo" 
          name="id_equipo" 
          required 
          class="w-full px-4 py-3 bg-slate-950/80 border border-sky-900/60 rounded-2xl text-white focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 touch-target text-base"
        >
          <option value="">-- Primero selecciona un Área --</option>
        </select>
      </div>

      <div>
        <label for="descripcion" class="block text-xs font-bold text-sky-200 uppercase tracking-wider mb-2">
          3. Describe Brevemente la Falla <span class="text-orange-400">*</span>
        </label>
        <textarea 
          id="descripcion" 
          name="descripcion" 
          rows="4" 
          required 
          placeholder="Ej: Falla en la etiquetadora térmica, la PC de control no enciende o cayó la red Wi-Fi..."
          class="w-full px-4 py-3 bg-slate-950/80 border border-sky-900/60 rounded-2xl text-white placeholder-slate-500 focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 text-base"
        ></textarea>
      </div>

      <button 
        type="submit" 
        id="btnSendTicket"
        class="w-full touch-target bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-extrabold rounded-2xl transition-all shadow-lg shadow-orange-500/30 active:scale-[0.98] flex items-center justify-center text-lg uppercase tracking-wide"
      >
        <svg class="w-6 h-6 mr-2 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
        <span>Enviar Reporte</span>
      </button>
    </form>
  </div>

  <!-- SECCIÓN 2: HISTORIAL DE MIS REPORTES (EXCLUSIVO DEL OPERARIO LOGUEADO) -->
  <div id="sectionMyTickets" class="hidden bg-slate-900/90 border border-sky-900/50 rounded-3xl shadow-2xl p-6 sm:p-8 backdrop-blur-xl space-y-4">
    <div class="flex items-center justify-between pb-3 border-b border-sky-900/50">
      <div>
        <h3 class="text-lg font-bold text-white">Historial de Mis Reportes</h3>
        <p class="text-xs text-sky-300">Monitorea el estado de tus peticiones personales enviadas a TI</p>
      </div>
      <button id="btnRefreshMyTickets" class="text-xs bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-xl border border-sky-900/40">Actualizar</button>
    </div>

    <div id="myTicketsList" class="space-y-3 max-h-96 overflow-y-auto">
      <p class="text-xs text-slate-500 text-center py-6">Cargando mis reportes en curso...</p>
    </div>
  </div>
</div>

<script>
  interface Ticket {
    id_ticket: number;
    id_usuario: number;
    nombre_usuario?: string;
    id_equipo: number;
    nombre_equipo?: string;
    nombre_area?: string;
    descripcion: string;
    estado: 'Pendiente' | 'En Proceso' | 'Resuelto';
    fecha_reporte: string;
  }

  let catalogEquipos: Array<{ id_equipo: number; id_area: number; tipo_equipo: string }> = [];

  const tabNewTicket = document.getElementById('tabNewTicket') as HTMLButtonElement;
  const tabMyTickets = document.getElementById('tabMyTickets') as HTMLButtonElement;
  const sectionNewTicket = document.getElementById('sectionNewTicket') as HTMLDivElement;
  const sectionMyTickets = document.getElementById('sectionMyTickets') as HTMLDivElement;
  const myTicketsList = document.getElementById('myTicketsList') as HTMLDivElement;
  const btnRefreshMyTickets = document.getElementById('btnRefreshMyTickets') as HTMLButtonElement;

  const selectArea = document.getElementById('selectArea') as HTMLSelectElement;
  const selectEquipo = document.getElementById('selectEquipo') as HTMLSelectElement;
  const ticketForm = document.getElementById('ticketForm') as HTMLFormElement;
  const successAlert = document.getElementById('ticketSuccessAlert') as HTMLDivElement;
  const successMsg = document.getElementById('ticketSuccessMessage') as HTMLSpanElement;
  const errorAlert = document.getElementById('ticketErrorAlert') as HTMLDivElement;
  const errorMsg = document.getElementById('ticketErrorMessage') as HTMLSpanElement;
  const btnSend = document.getElementById('btnSendTicket') as HTMLButtonElement;

  if (tabNewTicket && tabMyTickets) {
    tabNewTicket.addEventListener('click', () => {
      tabNewTicket.className = 'pb-3 px-2 font-bold text-sm text-orange-400 border-b-2 border-orange-500 flex items-center space-x-2 transition-all';
      tabMyTickets.className = 'pb-3 px-2 font-bold text-sm text-slate-400 hover:text-sky-300 border-b-2 border-transparent transition-all flex items-center space-x-2';
      sectionNewTicket.classList.remove('hidden');
      sectionMyTickets.classList.add('hidden');
    });

    tabMyTickets.addEventListener('click', () => {
      tabMyTickets.className = 'pb-3 px-2 font-bold text-sm text-orange-400 border-b-2 border-orange-500 flex items-center space-x-2 transition-all';
      tabNewTicket.className = 'pb-3 px-2 font-bold text-sm text-slate-400 hover:text-sky-300 border-b-2 border-transparent transition-all flex items-center space-x-2';
      sectionMyTickets.classList.remove('hidden');
      sectionNewTicket.classList.add('hidden');
      fetchMyTickets();
    });
  }

  async function fetchMyTickets() {
    try {
      myTicketsList.innerHTML = `<p class="text-xs text-slate-500 text-center py-6">Cargando mis reportes...</p>`;
      // Invocación del endpoint con el parámetro mine=true para obtener únicamente los del operario actual
      const res = await fetch('/api/tickets?mine=true');
      const tickets: Ticket[] = await res.json();
      renderMyTickets(tickets);
    } catch (err) {
      myTicketsList.innerHTML = `<p class="text-xs text-red-400 text-center py-6">Error al obtener historial personal.</p>`;
    }
  }

  function renderMyTickets(tickets: Ticket[]) {
    if (!tickets || tickets.length === 0) {
      myTicketsList.innerHTML = `<p class="text-xs text-slate-500 text-center py-6">No has enviado ningún reporte personal aún.</p>`;
      return;
    }

    myTicketsList.innerHTML = '';
    tickets.forEach((t) => {
      const card = document.createElement('div');
      card.className = 'bg-slate-950/80 border border-sky-900/40 p-4 rounded-2xl space-y-1.5';

      let statusBadge = 'bg-red-500/10 text-red-400 border-red-500/30';
      if (t.estado === 'En Proceso') statusBadge = 'bg-orange-500/10 text-orange-400 border-orange-500/30';
      if (t.estado === 'Resuelto') statusBadge = 'bg-emerald-500/10 text-emerald-400 border-emerald-500/30';

      const formattedDate = new Date(t.fecha_reporte).toLocaleString('es-MX', {
        day: '2-digit',
        month: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
      });

      card.innerHTML = `
        <div class="flex items-center justify-between text-xs">
          <span class="font-mono font-bold text-orange-400">#TK-${t.id_ticket} - ${t.nombre_equipo || 'Equipo TI'}</span>
          <span class="px-2.5 py-0.5 rounded-full text-xs font-bold border ${statusBadge}">${t.estado}</span>
        </div>
        <p class="text-sm font-medium text-white">${t.descripcion}</p>
        <div class="flex justify-between items-center text-xs text-slate-400 pt-1 border-t border-sky-900/20">
          <span>Área: ${t.nombre_area || 'Área de Hilado'}</span>
          <span>${formattedDate}</span>
        </div>
      `;
      myTicketsList.appendChild(card);
    });
  }

  if (btnRefreshMyTickets) {
    btnRefreshMyTickets.addEventListener('click', fetchMyTickets);
  }

  async function loadCatalogs() {
    try {
      const res = await fetch('/api/catalogs');
      const data = await res.json();
      if (data.areas && selectArea) {
        selectArea.innerHTML = '<option value="">-- Seleccionar Área --</option>';
        data.areas.forEach((area: any) => {
          const opt = document.createElement('option');
          opt.value = area.id_area;
          opt.textContent = area.nombre_area;
          selectArea.appendChild(opt);
        });
      }
      if (data.equipos) {
        catalogEquipos = data.equipos;
      }
    } catch (err) {
      console.error('Error cargando catálogos:', err);
    }
  }

  if (selectArea) {
    selectArea.addEventListener('change', () => {
      const selectedAreaId = parseInt(selectArea.value, 10);
      selectEquipo.innerHTML = '<option value="">-- Selecciona el Equipo de TI --</option>';
      if (!isNaN(selectedAreaId)) {
        const filtered = catalogEquipos.filter((e) => e.id_area === selectedAreaId);
        if (filtered.length > 0) {
          filtered.forEach((eq) => {
            const opt = document.createElement('option');
            opt.value = eq.id_equipo.toString();
            opt.textContent = eq.tipo_equipo;
            selectEquipo.appendChild(opt);
          });
        } else {
          catalogEquipos.forEach((eq) => {
            const opt = document.createElement('option');
            opt.value = eq.id_equipo.toString();
            opt.textContent = eq.tipo_equipo;
            selectEquipo.appendChild(opt);
          });
        }
      }
    });
  }

  if (ticketForm) {
    ticketForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      successAlert.classList.add('hidden');
      errorAlert.classList.add('hidden');
      btnSend.disabled = true;
      btnSend.innerText = 'Enviando...';

      const id_equipo = selectEquipo.value;
      const descripcion = (document.getElementById('descripcion') as HTMLTextAreaElement).value;

      try {
        const res = await fetch('/api/tickets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id_equipo, descripcion }),
        });

        const data = await res.json();

        if (res.ok && data.success) {
          successMsg.innerText = data.message || 'Reporte Enviado Exitosamente';
          successAlert.classList.remove('hidden');
          ticketForm.reset();
        } else {
          errorMsg.innerText = data.error || 'Ocurrió un error al registrar la orden.';
          errorAlert.classList.remove('hidden');
        }
      } catch (err) {
        errorMsg.innerText = 'Error de conexión con el servidor.';
        errorAlert.classList.remove('hidden');
      } finally {
        btnSend.disabled = false;
        btnSend.innerText = 'Enviar Reporte';
      }
    });
  }

  loadCatalogs();
</script>
