---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Sistema Web de Gestión y Digitalización de Órdenes de Trabajo - Fibras del Naranjo' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="h-full bg-slate-950 text-slate-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Fibras del Naranjo</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        font-family: 'Outfit', 'Inter', system-ui, -apple-system, sans-serif;
      }
      .touch-target {
        min-height: 48px;
      }
      /* Animaciones de Entrada */
      @keyframes appFadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes pulseGlow {
        0%, 100% { transform: scale(1); opacity: 0.9; }
        50% { transform: scale(1.08); opacity: 1; }
      }
      .animate-app-enter {
        animation: appFadeIn 0.5s ease-out forwards;
      }
      .animate-pulse-glow {
        animation: pulseGlow 2s infinite ease-in-out;
      }
    </style>
  </head>
  <body class="h-full flex flex-col antialiased selection:bg-orange-500 selection:text-white bg-gradient-to-br from-slate-950 via-slate-900 to-sky-950">
    
    <!-- Animación de Bienvenida al Arrancar la Aplicación -->
    <div id="appSplashLoader" class="fixed inset-0 z-50 bg-slate-950 flex flex-col items-center justify-center transition-opacity duration-500">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-tr from-orange-600 via-orange-500 to-sky-500 flex items-center justify-center text-white font-extrabold text-2xl shadow-2xl shadow-orange-500/40 animate-pulse-glow mb-4">
        FN
      </div>
      <h2 class="text-xl font-bold text-white tracking-wide">Fibras del Naranjo</h2>
      <p class="text-xs text-sky-400 mt-1 font-medium">Soporte Técnico de TI & Control Digital</p>
      <div class="w-32 h-1 bg-slate-800 rounded-full mt-6 overflow-hidden">
        <div class="h-full bg-gradient-to-r from-orange-500 to-sky-400 animate-pulse w-full"></div>
      </div>
    </div>

    <header class="bg-slate-900/90 backdrop-blur-md border-b border-sky-900/40 sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center space-x-3 group">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center font-black text-white text-xl shadow-lg shadow-orange-500/25 group-hover:scale-105 transition-transform">
            FN
          </div>
          <div>
            <h1 class="text-lg font-bold tracking-tight text-white leading-none">Fibras del Naranjo</h1>
            <p class="text-xs text-sky-400 font-semibold">Plataforma Digital de TI</p>
          </div>
        </a>

        <nav class="flex items-center space-x-3">
          <a href="/operario" class="text-xs sm:text-sm font-semibold text-slate-200 hover:text-orange-400 bg-slate-800/80 hover:bg-slate-800 px-3 py-2 rounded-xl border border-sky-900/40 transition-colors flex items-center space-x-1.5">
            <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            <span>Reportar Falla</span>
          </a>

          <a href="/dashboard" class="text-xs sm:text-sm font-semibold text-slate-200 hover:text-orange-400 bg-slate-800/80 hover:bg-slate-800 px-3 py-2 rounded-xl border border-sky-900/40 transition-colors flex items-center space-x-1.5">
            <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <span>Dashboard TI</span>
          </a>

          <a href="/" class="text-xs font-extrabold bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white px-4 py-2 rounded-xl transition-all shadow-lg shadow-orange-500/20">
            Login
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 animate-app-enter">
      <slot />
    </main>

    <footer class="bg-slate-900/90 border-t border-sky-900/40 text-slate-400 py-4 text-center text-xs">
      <div class="max-w-7xl mx-auto px-4">
        <p>&copy; {new Date().getFullYear()} Fibras del Naranjo S.A. de C.V. - Tepeji del Río, Hidalgo. Sistema de Gestión Local (SSR).</p>
      </div>
    </footer>

    <script>
      // Control de la animación de bienvenida al arrancar la aplicación
      window.addEventListener('DOMContentLoaded', () => {
        const loader = document.getElementById('appSplashLoader');
        if (loader) {
          setTimeout(() => {
            loader.style.opacity = '0';
            setTimeout(() => {
              loader.style.display = 'none';
            }, 500);
          }, 600);
        }
      });
    </script>
  </body>
</html>
